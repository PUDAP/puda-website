---
import HeaderLink from "./HeaderLink.astro";
import config from "../content/config/config.json";
import IconLink from "./react/IconLink";
---

<header>
	<nav>
		<h2><a href="/">{config.seo.title}</a></h2>
		<div class="internal-links">
			{
				config.nav.map((nav) => (
					<HeaderLink href={nav.link}>{nav.title}</HeaderLink>
				))
			}
		</div>
		<div class="right-controls">
			<button
				id="theme-toggle"
				aria-label="Toggle light/dark mode"
				title="Toggle light/dark mode"
			>
				<!-- Sun icon — shown in light mode (click to go dark) -->
				<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="12" cy="12" r="4"/>
					<line x1="12" y1="2" x2="12" y2="6"/>
					<line x1="12" y1="18" x2="12" y2="22"/>
					<line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/>
					<line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/>
					<line x1="2" y1="12" x2="6" y2="12"/>
					<line x1="18" y1="12" x2="22" y2="12"/>
					<line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/>
					<line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/>
				</svg>
				<!-- Moon icon — shown in dark mode (click to go light) -->
				<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
				</svg>
			</button>
		</div>
	</nav>
</header>

<script>
	function applyTheme(theme: string) {
		document.documentElement.setAttribute('data-theme', theme);
		localStorage.setItem('theme', theme);
	}

	function restoreTheme() {
		const stored = localStorage.getItem('theme');
		const theme = stored ?? 'dark';
		document.documentElement.setAttribute('data-theme', theme);
	}

	function initToggle() {
		const btn = document.getElementById('theme-toggle');
		if (!btn) return;
		btn.addEventListener('click', () => {
			const current = document.documentElement.getAttribute('data-theme') ?? 'dark';
			applyTheme(current === 'dark' ? 'light' : 'dark');
		});
	}

	initToggle();

	// After each client-side navigation the <html> element is swapped in fresh
	// (without data-theme), so we must re-apply the stored preference.
	document.addEventListener('astro:after-swap', () => {
		restoreTheme();
		initToggle();
	});
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		margin: 0;
		padding: 0 1em;
		background: var(--header-bg);
		backdrop-filter: blur(20px) saturate(180%);
		-webkit-backdrop-filter: blur(20px) saturate(180%);
		border-bottom: 1px solid var(--header-border);
		transition: background 0.2s ease, border-color 0.2s ease;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--header-fg);
		transition: color 0.15s;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--header-nav-fg);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		transition: color 0.15s;
	}
	nav a:hover {
		color: var(--header-nav-hover);
	}
	nav a.active {
		text-decoration: none;
		color: var(--header-nav-hover);
		border-bottom-color: var(--accent);
	}
	.right-controls {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}
	.social-links,
	.social-links a {
		display: flex;
	}

	/* Theme toggle button */
	#theme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border-radius: 50%;
		border: none;
		cursor: pointer;
		background: var(--toggle-bg);
		color: var(--toggle-fg);
		transition: background 0.15s ease, color 0.15s ease;
		flex-shrink: 0;
	}
	#theme-toggle:hover {
		background: var(--toggle-hover-bg);
	}

	/* Show/hide icons based on current theme */
	:root .icon-sun,
	[data-theme="dark"] .icon-sun { display: none; }
	:root .icon-moon,
	[data-theme="dark"] .icon-moon { display: block; }

	[data-theme="light"] .icon-sun { display: block; }
	[data-theme="light"] .icon-moon { display: none; }

	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
