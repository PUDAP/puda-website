---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { Replay } from "../components/demo/replay";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="PUDA Demo"
      description="Explore the latest 3 hour PUDA run"
    />
  </head>

  <body class="min-h-screen bg-[#080908] text-white">
    <Header />
    <section class="relative overflow-hidden px-6 py-6 md:px-12 lg:px-20">

      <!-- Background layers -->
      <div class="absolute inset-0 bg-[linear-gradient(rgba(232,255,156,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(232,255,156,0.06)_1px,transparent_1px)] bg-size-[120px_120px] opacity-45" />
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_12%,rgba(232,255,156,0.15),transparent_34%),radial-gradient(circle_at_86%_18%,rgba(87,190,255,0.12),transparent_32%),radial-gradient(circle_at_50%_100%,rgba(212,160,75,0.10),transparent_38%)]" />
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(0,0,0,0.24)_46%,rgba(0,0,0,0.78)_100%)]" />

      <!-- Content -->
        <div class="relative z-10 mx-auto flex min-h-[calc(100svh-5rem)] max-w-368 flex-col justify-center gap-10 py-12 lg:py-16">

        <!-- Hero -->
        <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
          <div class="flex flex-col justify-center">
            <p class="mb-5 text-xs uppercase tracking-[0.42em] text-[#e8ff9c]">Demo</p>
            <h1 class="max-w-4xl text-balance text-5xl font-normal tracking-[-0.065em] md:text-7xl lg:text-[5.8rem] lg:leading-[0.9]">
              3 hour run
            </h1>
            <div class="mt-6 flex flex-wrap gap-3">
              <span class="rounded-full border border-[#e8ff9c]/25 bg-[#e8ff9c]/10 px-4 py-2 font-mono text-xs text-[#e8ff9c]">
                178 turns
              </span>
              <span class="rounded-full border border-[#57beff]/25 bg-[#57beff]/10 px-4 py-2 font-mono text-xs text-[#bde9ff]">
                181 requested actions
              </span>
              <span class="rounded-full border border-white/15 bg-white/6 px-4 py-2 font-mono text-xs text-white/72">
                155 safe auto-executions
              </span>
            </div>
          </div>
          <div class="flex items-center">
            <p class="max-w-2xl text-lg leading-8 text-white/64 md:text-xl md:leading-9">
              The latest three-hour puda run becomes inspectable: conversation, requested tools, safe auto-executions, rejected unsupported actions, and PUDA needs stay aligned in one replay.
            </p>
          </div>
        </div>

        <!-- Interactive replay -->
        <Replay client:load />
      </div>

    </section>
  </body>
</html>
