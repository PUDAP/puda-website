---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { Replay } from "../components/demo/replay";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="PUDA Demo"
      description="Explore the latest 3 hour PUDA run"
    />
  </head>

  <body class="demo-body min-h-screen">
    <Header />
    <section class="relative overflow-hidden px-6 py-6 md:px-12 lg:px-20">

      <!-- Background layers -->
      <div class="demo-grid-bg absolute inset-0 bg-[linear-gradient(rgba(232,255,156,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(232,255,156,0.06)_1px,transparent_1px)] bg-size-[120px_120px] opacity-45" />
      <div class="demo-radial-bg absolute inset-0 bg-[radial-gradient(circle_at_18%_12%,rgba(232,255,156,0.15),transparent_34%),radial-gradient(circle_at_86%_18%,rgba(87,190,255,0.12),transparent_32%),radial-gradient(circle_at_50%_100%,rgba(212,160,75,0.10),transparent_38%)]" />
      <div class="demo-vignette absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(0,0,0,0.24)_46%,rgba(0,0,0,0.78)_100%)]" />

      <!-- Content -->
        <div class="relative z-10 mx-auto flex min-h-[calc(100svh-5rem)] max-w-7xl flex-col justify-center gap-10 py-12 lg:py-16">

        <!-- Hero -->
        <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
          <div class="flex flex-col justify-center">
            <p class="demo-label mb-5 text-xs uppercase tracking-[0.42em]">Demo</p>
            <h1 class="demo-heading max-w-4xl text-balance text-5xl font-normal tracking-[-0.065em] md:text-7xl lg:text-[5.8rem] lg:leading-[0.9]">
              3 hour run
            </h1>
            <div class="mt-6 flex flex-wrap gap-3">
              <span class="demo-badge-lime rounded-full border px-4 py-2 font-mono text-xs">
                178 turns
              </span>
              <span class="demo-badge-blue rounded-full border px-4 py-2 font-mono text-xs">
                181 requested actions
              </span>
              <span class="demo-badge-neutral rounded-full border px-4 py-2 font-mono text-xs">
                155 safe auto-executions
              </span>
            </div>
          </div>
          <div class="flex items-center">
            <p class="demo-subtitle max-w-2xl text-lg leading-8 md:text-xl md:leading-9">
              The latest three-hour puda run becomes inspectable: conversation, requested tools, safe auto-executions, rejected unsupported actions, and PUDA needs stay aligned in one replay.
            </p>
          </div>
        </div>

        <!-- Interactive replay -->
        <Replay client:load />
      </div>

    </section>
  </body>
</html>

<style>
  .demo-body {
    background-color: var(--bg-primary);
    color: var(--fg-primary);
    transition: background-color 0.25s ease, color 0.2s ease;
  }

  .demo-label {
    color: var(--accent);
  }

  .demo-heading {
    color: var(--fg-primary);
  }

  .demo-subtitle {
    color: var(--fg-secondary);
  }

  /* Lime badge */
  .demo-badge-lime {
    border-color: rgba(232, 255, 156, 0.25);
    background: rgba(232, 255, 156, 0.10);
    color: #e8ff9c;
  }
  [data-theme="light"] .demo-badge-lime {
    border-color: rgba(67, 114, 0, 0.25);
    background: rgba(67, 114, 0, 0.08);
    color: #437200;
  }

  /* Blue badge */
  .demo-badge-blue {
    border-color: rgba(87, 190, 255, 0.25);
    background: rgba(87, 190, 255, 0.10);
    color: #bde9ff;
  }
  [data-theme="light"] .demo-badge-blue {
    border-color: rgba(0, 120, 180, 0.20);
    background: rgba(0, 120, 180, 0.07);
    color: #005f8e;
  }

  /* Neutral badge — dark default */
  .demo-badge-neutral {
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.72);
  }
  [data-theme="light"] .demo-badge-neutral {
    border-color: rgba(13, 17, 13, 0.12);
    background: rgba(13, 17, 13, 0.04);
    color: rgba(13, 17, 13, 0.65);
  }

  /* Hide decorative layers in light mode */
  [data-theme="light"] .demo-grid-bg,
  [data-theme="light"] .demo-radial-bg,
  [data-theme="light"] .demo-vignette {
    display: none;
  }
</style>
