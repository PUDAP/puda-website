---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MosaicHero from '../components/home/MosaicHero.astro';
import CliAnimation from '../components/home/CliAnimation.astro';
import VideoPlaceholder from '../components/VideoPlaceholder.astro';
const DEMO_VIDEO_EMBED =
  "https://drive.google.com/file/d/1F84zg_8aLqi-RfEFEOLKW08hYToD4S0b/preview";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="PUDA — Physical Unified Device Architecture"
      description="PUDA connects AI agents to instruments, robots, datastreams, approvals, and audit trails."
    />
  </head>
  <body class="min-h-screen flex flex-col">

    <Header />

    <!-- Hero -->
    <section class="hero-section relative min-h-[100svh]">
      <MosaicHero />

      <div id="top" class="relative z-10 mx-auto flex min-h-[100svh] max-w-7xl flex-col items-center justify-center px-6 py-20 text-center">
        <h1 class="hero-title max-w-6xl text-balance text-4xl font-normal tracking-[-0.065em] md:text-5xl lg:text-[4.8rem] lg:leading-[0.94]">
          The runtime environment for Physical AI
        </h1>
        <p class="hero-subtitle mt-5 max-w-3xl text-balance text-base leading-7 md:text-xl md:leading-8">
          PUDA (Physical Unified Device Architecture) connects AI agents to instruments, robots, datastreams, approvals, and audit trails.
        </p>
        <CliAnimation />
        <div class="mt-9 flex flex-col items-center gap-3 sm:flex-row">
          <a class="cta-primary rounded-full px-6 py-3 text-sm font-medium transition" href="#video">
            Watch the demo
          </a>
          <a class="cta-secondary rounded-full border px-6 py-3 text-sm transition" href="/demo">
            Explore demo
          </a>
        </div>
      </div>
    </section>

    <!-- Video demo -->
    <section id="video" class="video-section flex min-h-[100svh] items-center px-6 py-16 md:px-12 lg:px-20">
      <div class="mx-auto w-full max-w-[92rem]">
        <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between lg:mb-10">
          <div>
            <p class="demo-label mb-4 text-xs uppercase tracking-[0.42em]">Demo</p>
            <h2 class="video-heading text-5xl font-normal tracking-[-0.065em] md:text-7xl">
              See PUDA in motion.
            </h2>
          </div>
        </div>
        <VideoPlaceholder embedSrc={DEMO_VIDEO_EMBED} title="PUDA demo video" />
      </div>
    </section>

    <Footer />

  </body>
</html>

<style is:global>
  body {
    background-color: var(--bg-primary);
    color: var(--fg-primary);
    transition: background-color 0.25s ease, color 0.2s ease;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .hero-section {
    background-color: var(--bg-primary);
    color: var(--fg-primary);
    transition: background-color 0.25s ease;
  }

  .hero-title {
    color: var(--fg-primary);
  }

  .hero-subtitle {
    color: var(--fg-secondary);
  }

  .cta-primary {
    background-color: var(--accent-lime);
    color: var(--accent-lime-fg);
  }
  .cta-primary:hover {
    background-color: #ffffff;
  }
  [data-theme="light"] .cta-primary:hover {
    background-color: #d0f060;
  }

  .cta-secondary {
    border-color: var(--cta-border);
    color: var(--cta-fg);
  }
  .cta-secondary:hover {
    background-color: var(--cta-hover-bg);
  }

  .video-section {
    flex: 1;
    background-color: var(--bg-secondary);
    transition: background-color 0.25s ease;
  }

  .demo-label {
    color: var(--accent-label);
  }

  .video-heading {
    color: var(--fg-primary);
  }
</style>
