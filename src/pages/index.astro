---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import MosaicHero from '../components/home/MosaicHero.astro';
import CliAnimation from '../components/home/CliAnimation.astro';
import VideoPlaceholder from '../components/VideoPlaceholder.astro';
const DEMO_VIDEO_EMBED =
  "https://drive.google.com/file/d/1F84zg_8aLqi-RfEFEOLKW08hYToD4S0b/preview";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="PUDA — Physical Unified Device Architecture"
      description="PUDA connects AI agents to instruments, robots, datastreams, approvals, and audit trails."
    />
  </head>
  <body class="min-h-screen bg-[#080908] text-white">

    <Header />

    <!-- Hero -->
    <section class="relative min-h-[100svh] bg-[#080908] text-white">
      <MosaicHero />

      <div id="top" class="relative z-10 mx-auto flex min-h-[100svh] max-w-7xl flex-col items-center justify-center px-6 py-20 text-center">
        <h1 class="max-w-6xl text-balance text-4xl font-normal tracking-[-0.065em] text-white md:text-5xl lg:text-[4.8rem] lg:leading-[0.94]">
          The runtime environment for Physical AI
        </h1>
        <p class="mt-5 max-w-3xl text-balance text-base leading-7 text-white/70 md:text-xl md:leading-8">
          PUDA (Physical Unified Device Architecture) connects AI agents to instruments, robots, datastreams, approvals, and audit trails.
        </p>
        <CliAnimation />
        <div class="mt-9 flex flex-col items-center gap-3 sm:flex-row">
          <a
            class="rounded-full bg-[#e8ff9c] px-6 py-3 text-sm font-medium text-[#080908] transition hover:bg-white"
            href="#video"
          >
            Watch the demo
          </a>
          <a
            class="rounded-full border border-white/15 px-6 py-3 text-sm text-white/80 transition hover:bg-white/10"
            href="/demo"
          >
            Explore demo
          </a>
        </div>
      </div>
    </section>

    <!-- Video demo -->
    <section id="video" class="flex min-h-[100svh] items-center bg-[#111] px-6 py-16 md:px-12 lg:px-20">
      <div class="mx-auto w-full max-w-[92rem]">
        <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between lg:mb-10">
          <div>
            <p class="mb-4 text-xs uppercase tracking-[0.42em] text-[#e8ff9c]">Demo</p>
            <h2 class="text-5xl font-normal tracking-[-0.065em] text-white md:text-7xl">
              See PUDA in motion.
            </h2>
          </div>
        </div>
        <VideoPlaceholder embedSrc={DEMO_VIDEO_EMBED} title="PUDA demo video" />
      </div>
    </section>

  </body>
</html>
